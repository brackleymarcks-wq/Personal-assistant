# Telegram Bot Token (получен от @BotFather)
TELEGRAM_BOT_TOKEN=ваш_токен_сюда

# Ваш Telegram Chat ID (узнаете после первого /start)
TELEGRAM_CHAT_ID=

# Supabase
SUPABASE_URL=https://ваш-проект.supabase.co
SUPABASE_KEY=ваш_anon_key

# OpenRouter API Key (для ИИ-ответов)
OPENROUTER_API_KEY=ваш_ключ
